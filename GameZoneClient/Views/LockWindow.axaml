<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameZoneClient.Views.LockWindow"
        Title="GameZone - Bilgisayar Kilitli"
        Width="450" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#121212">
        <Border BorderBrush="#ff0055" BorderThickness="3" CornerRadius="15" Margin="20">
		<Grid RowDefinitions="Auto, *, Auto" Margin="20">
			
			<StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="10">
				<TextBlock Text="🎮 GAMEZONE" FontSize="28" FontWeight="ExtraBold" Foreground="#ff0055" HorizontalAlignment="Center"/>
				<TextBlock Name="LblLockStatus" Text="Kilitli Ekran - Oturum Açın" FontSize="14" Foreground="#888888" HorizontalAlignment="Center"/>
			</StackPanel>

			<StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="20">
				<Border Background="#1e1e1e" CornerRadius="10" Padding="15">
					<TextBlock Text="Aşağıdaki alandan bakiye yükleyerek sürenizi anında başlatabilirsiniz." 
							   Foreground="#aaaaaa" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
				</Border>

				<StackPanel Spacing="10">
					<TextBlock Text="Yüklenecek Tutar (TL):" Foreground="#ffffff" FontSize="13" FontWeight="Bold"/>
					<TextBox Name="TxtDepositAmount" Watermark="Örn: 50" FontSize="16" Background="#2d2d2d" Foreground="White" Height="40"/>
				</StackPanel>

				<Button Name="BtnDepositBalance" Content="💳 Kredi Kartı ile Bakiye Yükle" Background="#ff0055" Foreground="White" FontWeight="Bold" FontSize="14" Height="45" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
			</StackPanel>

			<TextBlock Grid.Row="2" Text="GameZone Otomasyon Sistemi v1.0" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,10"/>
		</Grid>
	</Border>
</Window>